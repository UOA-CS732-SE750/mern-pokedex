{
  "name": "cs732-pokedex-demo",
  "version": "1.0.0",
  "private": true,
  "description": "Full-stack Pokedex demo application for CS732",
  "workspaces": [
    "frontend",
    "backend"
  ],
  "scripts": {
    "dev": "concurrently -c \"cyan.bold,magenta.bold\" \"npm:dev:frontend\" \"npm:dev:backend\"",
    "dev:frontend": "npm run dev --workspace=frontend",
    "dev:backend": "npm run dev --workspace=backend",
    "build": "npm run build --workspace=frontend",
    "start": "npm run start --workspace=backend",
    "install:all": "npm install",
    "init-db": "npm run init-db --workspace=backend",
    "test:frontend": "npm run test --workspace=frontend",
    "test:backend": "npm run test --workspace=backend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "prettier": "^3.2.4",
    "vite": "^7.3.1",
    "vitest": "^4.1.5"
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
